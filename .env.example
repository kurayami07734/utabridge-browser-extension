# API Configuration
# Copy this file to .env and update the values
VITE_API_BASE_URL=http://localhost:8080

# Google OAuth Configuration
# Get your client ID from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Extension Public Key (for consistent extension ID)
# Generate at: https://itero.plasmo.com/tools/generate-keypairs
# This is the BASE64_PUBLIC_KEY, not the CRX_ID
VITE_EXTENSION_PUBLIC_KEY=
